{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACDP Message",
  "description": "Schema for Agent Communication Protocol messages appended to events.log",
  "type": "object",
  "required": ["type", "agent", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "register",
        "intent",
        "lock",
        "release",
        "update",
        "complete",
        "wait",
        "block",
        "resolve",
        "notify",
        "request",
        "ack"
      ],
      "description": "Message type"
    },
    "agent": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Agent identifier (kebab-case)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "data": {
      "type": "object",
      "description": "Type-specific payload"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "register" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["role"],
            "properties": {
              "role": { "type": "string", "enum": ["developer", "reviewer", "ops", "architect"] },
              "public_key": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "intent" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["task", "branch"],
            "properties": {
              "task": { "type": "string" },
              "branch": { "type": "string" },
              "resources": { "type": "array", "items": { "type": "string" } },
              "base_coord_rev": { "type": "string", "description": "Remote coordination revision observed before mutating, when remote-first mode is active" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "lock" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["resource", "reason"],
            "properties": {
              "resource": { "type": "string" },
              "scope": { "type": "string", "enum": ["file", "directory"], "description": "Lock granularity. Defaults to file for paths with extensions, directory for paths ending in /" },
              "reason": { "type": "string" },
              "ttl_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
              "renewal": { "type": "boolean", "description": "True if this is a lock renewal, not a new acquisition" },
              "branch": { "type": "string", "description": "Working branch carrying the change that required the lock" },
              "lock_id": { "type": "string", "description": "Stable unique identifier for the lock lifecycle" },
              "base_coord_rev": { "type": "string", "description": "Remote coordination revision observed before the lock mutation" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "release" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["resource"],
            "properties": {
              "resource": { "type": "string" },
               "expired": { "type": "boolean", "description": "True if lock was released due to TTL expiration" },
               "override": { "type": "boolean", "description": "True if lock was force-released by a maintainer" },
               "branch": { "type": "string", "description": "Working branch associated with the released lock, when relevant" },
               "lock_id": { "type": "string", "description": "Stable unique identifier for the lock lifecycle" },
               "base_coord_rev": { "type": "string", "description": "Remote coordination revision observed before the release mutation" },
               "coordination_mode": { "type": "string", "enum": ["legacy", "remote-first"], "description": "Coordination mode used when the release was emitted" },
               "coordination_branch": { "type": "string", "description": "Coordination branch reference used for the release event when relevant" }
             }
           }
         }
       }
     },
    {
      "if": { "properties": { "type": { "const": "update" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["task"],
            "properties": {
              "task": { "type": "string" },
              "progress": { "type": "string" },
              "details": { "type": "string" },
              "branch": { "type": "string", "description": "Working branch associated with this update" },
              "heartbeat": { "type": "boolean", "description": "True when the update is a lightweight liveness heartbeat" },
              "lock_id": { "type": "string", "description": "Stable lock identifier related to the update, when relevant" },
              "base_coord_rev": { "type": "string", "description": "Remote coordination revision observed before the update mutation" },
              "coordination_mode": { "type": "string", "enum": ["legacy", "remote-first"], "description": "Coordination mode used for the update" },
              "coordination_branch": { "type": "string", "description": "Coordination branch reference used for the update when relevant" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "complete" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["task", "branch"],
            "properties": {
              "task": { "type": "string" },
              "branch": { "type": "string" },
              "summary": { "type": "string" },
              "lock_id": { "type": "string", "description": "Stable unique identifier for the lock lifecycle related to this completion" },
              "base_coord_rev": { "type": "string", "description": "Remote coordination revision observed before the release/complete mutation" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "wait" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["resource", "held_by"],
            "properties": {
              "resource": { "type": "string" },
              "held_by": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "block" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["reason"],
            "properties": {
              "reason": { "type": "string" },
              "affected_resources": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "resolve" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["reference", "resolution"],
            "properties": {
              "reference": { "type": "string" },
              "resolution": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "notify" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["message"],
            "properties": {
              "message": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "request" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["to", "action"],
            "properties": {
              "to": { "type": "string" },
              "action": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "ack" } } },
      "then": {
        "properties": {
          "data": {
            "required": ["reference", "accepted"],
            "properties": {
              "reference": { "type": "string", "description": "Format: agent:type:timestamp" },
              "accepted": { "type": "boolean" }
            }
          }
        }
      }
    }
  ]
}
